<div id="confirm-modal" class="fixed inset-0 z-50 hidden bg-black bg-opacity-60 flex items-center justify-center transition-opacity duration-300 opacity-0">
    <div class="bg-gray-800 rounded-lg p-6 max-w-sm w-full mx-4 shadow-2xl transform scale-95 transition-transform duration-300">
        <h3 class="text-xl font-bold text-white mb-2" id="confirm-modal-title">¿Estás seguro?</h3>
        <p class="text-gray-300 mb-6" id="confirm-modal-message">Esta acción no se puede deshacer.</p>
        <div class="flex justify-end gap-3">
            <button id="confirm-modal-cancel" class="px-4 py-2 bg-gray-600 hover:bg-gray-500 text-white rounded font-medium transition">
                Cancelar
            </button>
            <button id="confirm-modal-accept" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded font-medium transition cursor-pointer">
                Aceptar
            </button>
        </div>
    </div>
</div>

<script src="/js/confirmModal.js"></script>
