<div class='bg-gray-800 rounded-lg p-8 w-full max-w-md'>
    <div class='flex justify-between items-center mb-6'>
        <h2 class='text-2xl font-bold text-white'>Crear Nuevo Producto</h2>
        <button onclick='closeCreateModal()' class='text-gray-400 hover:text-white'>
            <i class='fas fa-times text-2xl'></i>
        </button>
    </div>

    <form onsubmit="/api/products" method="POST" id='createProductForm' class='space-y-4'>
        <div>
            <label for="name" class='block text-sm font-medium text-gray-300 mb-1'>Título *</label>
            <input
                type='text'
                name='name'
                required
                class='w-full px-4 py-2 bg-gray-700 text-white rounded-lg border border-gray-600 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 outline-none transition'
            />
        </div>

        <div>
            <label for="description" class='block text-sm font-medium text-gray-300 mb-1'>Descripción *</label>
            <textarea
                name='description'
                required
                rows='3'
                class='w-full px-4 py-2 bg-gray-700 text-white rounded-lg border border-gray-600 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 outline-none transition'
            ></textarea>
        </div>

        <div class='grid grid-cols-2 gap-4'>
            <div>
                <label for="price" class='block text-sm font-medium text-gray-300 mb-1'>Precio *</label>
                <input
                    type='number'
                    name='price'
                    step='0.01'
                    required
                    class='w-full px-4 py-2 bg-gray-700 text-white rounded-lg border border-gray-600 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 outline-none transition'
                />
            </div>
            <div>
                <label for="stock" class='block text-sm font-medium text-gray-300 mb-1'>Stock *</label>
                <input
                    type='number'
                    name='stock'
                    required
                    class='w-full px-4 py-2 bg-gray-700 text-white rounded-lg border border-gray-600 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 outline-none transition'
                />
            </div>
        </div>

        <div class='grid grid-cols-2 gap-4'>
            <div>
                <label for="code" class='block text-sm font-medium text-gray-300 mb-1'>Código *</label>
                <input
                    type='text'
                    name='code'
                    required
                    class='w-full px-4 py-2 bg-gray-700 text-white rounded-lg border border-gray-600 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 outline-none transition'
                />
            </div>
            <div>
                <label for="category" class='block text-sm font-medium text-gray-300 mb-1'>Categoría *</label>
                <input
                    type='text'
                    name='category'
                    required
                    class='w-full px-4 py-2 bg-gray-700 text-white rounded-lg border border-gray-600 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 outline-none transition'
                />
            </div>
        </div>

        <div>
            <label for="thumbnails" class='block text-sm font-medium text-gray-300 mb-1'>URL Imagen (thumbnail)</label>
            <input
                type='url'
                name='thumbnails'
                placeholder='https://...'
                class='w-full px-4 py-2 bg-gray-700 text-white rounded-lg border border-gray-600 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 outline-none transition'
            />
        </div>

        <div class='flex items-center gap-2'>
            <input type='checkbox' name='status' id='statusCheck' class='w-4 h-4 rounded' />
            <label for='statusCheck' class='text-sm font-medium text-gray-300'>Producto activo</label>
        </div>

        <div class='flex gap-4 pt-4'>
            <button type='submit' class='flex-1 bg-green-600 text-white py-2 rounded-lg hover:bg-green-700 transition duration-200 font-semibold'>
                <i class='fas fa-save mr-2'></i>Crear
            </button>
            <button type='button' onclick='closeCreateModal()' class='flex-1 bg-gray-700 text-white py-2 rounded-lg hover:bg-gray-600 transition duration-200 font-semibold'>
                Cancelar
            </button>
        </div>
    </form>
</div>