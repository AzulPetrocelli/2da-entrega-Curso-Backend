<html lang='es'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<title>Productos - Sistema de Gestión</title>
		<script src='https://cdn.tailwindcss.com'></script>
		<link
			rel='stylesheet'
			href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css'
		/>
		<link
			rel='stylesheet'
			href="/public/css/index.css"
		/>
	</head>
	<body class='bg-gray-900 min-h-screen text-white'>
        <!-- Toaster de Notificaciones -->
        {{> toast}}

		<div class='container mx-auto px-4 py-8'>
			<div class='mb-8 text-center'>
				<h1 class='text-5xl font-bold text-blue-400 mb-2'>
					Catálogo de Productos
				</h1>
				<div class='mt-4'>
					<a href='/carts/69a7a6b91d450e5387aeedf3' class='text-3xl text-green-400  hover:underline hover:text-green-300 transition'>
                        <i class='fas fa-shopping-cart mr-2'></i>
						Ver Carrito
                    </a>
				</div>
			</div>

			<!-- Layout principal: barra lateral + contenido -->
			<div class='flex flex-col lg:flex-row gap-8'>

				<!-- Barra lateral -->
				<aside class='w-full lg:w-1/4 lg:flex-shrink-0 bg-gray-800 p-6 rounded-lg shadow-lg self-start sticky top-4'>
					<h2 class='text-2xl font-bold mb-4 border-b border-gray-700 pb-2'>
						<i class='fas fa-filter mr-2 text-blue-400'></i>Filtros
					</h2>
					{{> sidebar}}
				</aside>

				<!-- Contenido principal -->
				<div class='w-full lg:w-3/4'>

					<!-- Listado de productos -->
					{{#if products.length}}
						<div class='grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-6'>
							{{#each products}}
								{{> card}}
							{{/each}}
						</div>

						<!-- Controles de paginación -->
						<div class='mt-12 flex justify-center items-center gap-4'>
							{{#if pagination.hasPrevPage}}
								<a
									href='{{pagination.prevLink}}'
									class='px-4 py-2 bg-gray-700 rounded hover:bg-gray-600 transition'
								>
									<i class='fas fa-chevron-left'></i>
									Anterior
								</a>
							{{/if}}

							<span class='text-gray-400'>Página
								{{pagination.page}}
								de
								{{pagination.totalPages}}</span>

							{{#if pagination.hasNextPage}}
								<a
									href='{{pagination.nextLink}}'
									class='px-4 py-2 bg-gray-700 rounded hover:bg-gray-600 transition'
								>
									Siguiente
									<i class='fas fa-chevron-right'></i>
								</a>
							{{/if}}
						</div>
					{{else}}
						<!-- Mensaje de no productos -->
						<div class='text-center py-12 bg-gray-800 rounded-lg shadow-lg'>
							<i class='fas fa-search text-gray-600 text-6xl mb-4'></i>
							<p class='text-gray-400 text-xl'>No se encontraron productos con los filtros seleccionados.</p>
						</div>
					{{/if}}
				</div>
			</div>
		</div>

		<script src="/js/filter.js"></script>
		<script src="/js/cart.js"></script>
	</body>
</html>